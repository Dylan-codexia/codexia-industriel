# ──────────────────────────────────────────────
# CODEX INDUSTRIEL — Configuration
# Copie ce fichier en .env et remplis les valeurs
# ──────────────────────────────────────────────

# Base de données
# En local : SQLite (aucune installation requise)
DATABASE_URL=sqlite:///./codex.db

# En production PostgreSQL sur OVH :
# DATABASE_URL=postgresql://user:password@host:5432/codex_db

# Sécurité JWT — CHANGE cette valeur en production !
# Génère une clé avec : openssl rand -hex 32
SECRET_KEY=changeme_generate_a_real_secret_key_before_production
ALGORITHM=HS256

# Durée de validité du token de connexion (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080
